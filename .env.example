# Vurtnec Loom Environment Variables
# ===================================
# Copy this file to .env and fill in your credentials.
# Then: source .env (or add to ~/.zshrc)

# --- Feishu ---
# Custom bot webhook (for push notifications)
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_HOOK_ID
# App bot credentials (for receiving messages and triggering tasks)
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=your_app_secret_here

# --- WeChat ---
# ServerChan: https://sct.ftqq.com/
SERVERCHAN_KEY=your_serverchan_key
# WxPusher: https://wxpusher.zjiecode.com/
WXPUSHER_TOKEN=your_wxpusher_token
WXPUSHER_UID=your_wxpusher_uid

# --- DingTalk ---
# Custom bot webhook
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN

# --- Email ---
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# --- Microsoft Teams (delegated Graph access for the teams_message trigger) ---
# No client_id / secret needed by default — we borrow Microsoft's public
# "Microsoft Graph Command Line Tools" app id. Run `python teams_probe.py`
# once to log in via OAuth device code flow; the token cache is stored at
# ~/.claude-long-runner/teams_token_cache.json and silently refreshed thereafter.
#
# Personal Microsoft accounts (outlook.com / Teams Free) are NOT supported
# by the underlying Graph chat APIs — work or school accounts only.
#
# To override the client_id (e.g. you registered your own Entra ID app):
# TEAMS_GRAPH_CLIENT_ID=your_app_client_id
# TEAMS_GRAPH_AUTHORITY=https://login.microsoftonline.com/your-tenant-id

# --- Azure DevOps (for the PR review schedule) ---
# Login once with `az login` and `az extension add --name azure-devops`.
# Schedules invoke az CLI directly, so no token is stored here.

# --- Anthropic API (optional; if not set, uses Claude CLI subscription) ---
# ANTHROPIC_API_KEY=sk-ant-xxxxx
