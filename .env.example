# Claude Long-Runner Environment Variables
# ==========================================
# Copy this file to .env and fill in your credentials.
# Then: source .env (or add to ~/.zshrc)

# --- Feishu (飞书) ---
# 自定义机器人 Webhook (用于通知推送)
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_HOOK_ID
# 应用机器人凭据 (用于接收消息触发任务)
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=your_app_secret_here

# --- WeChat (微信) ---
# Server酱 (ServerChan): https://sct.ftqq.com/
SERVERCHAN_KEY=your_serverchan_key
# WxPusher: https://wxpusher.zjiecode.com/
WXPUSHER_TOKEN=your_wxpusher_token
WXPUSHER_UID=your_wxpusher_uid

# --- DingTalk (钉钉) ---
# 自定义机器人 Webhook
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN

# --- Email (邮件) ---
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# --- Anthropic API (可选，不设则使用 Claude CLI 订阅) ---
# ANTHROPIC_API_KEY=sk-ant-xxxxx
