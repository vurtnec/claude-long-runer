{
  "name": "satellica_unittest",
  "description": "为前端项目批量生成单元测试（Happy Path）- 需要通过 --params 传入 project_dir",
  "state_file": "unittest_state.json",
  "initial_state": {
    "phase": "generating",
    "pending_files": [],
    "completed_files": [],
    "failed_files": [],
    "skipped_files": [],
    "current_batch": [],
    "batch_size": 3,
    "total_files": 0,
    "pending_count": 0,
    "completed_count": 0,
    "failed_count": 0,
    "skipped_count": 0,
    "current_batch_display": "",
    "test_result": ""
  },
  "success_conditions": [
    {
      "type": "state_equals",
      "key": "phase",
      "value": "completed"
    }
  ],
  "delay_seconds": 3,
  "state_processor": "processor.py"
}
