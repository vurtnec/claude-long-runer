{
  "name": "feature_story",
  "description": "Feature Story template - step-by-step implementation based on project specification",
  "state_file": "feature_story_state.json",
  "spec_file": "spec.yaml",
  "browser_tool": "playwright",
  "allowed_commands": ["sqlite3"],
  "initial_state": {
    "spec_file": "spec.yaml",
    "phase": "initializing",
    "current_step": 1,
    "total_steps": 0,
    "completed_steps": [],
    "failed_steps": [],
    "current_step_title": "",
    "current_step_tasks": [],
    "current_step_acceptance": [],
    "project_name": "",
    "overview": "",
    "technology_stack": {}
  },
  "success_conditions": [
    {
      "type": "state_equals",
      "key": "phase",
      "value": "completed"
    }
  ],
  "delay_seconds": 3,
  "state_processor": "processor.py"
}
